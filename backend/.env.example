# Smart Slot — Backend Environment Variables
# ==========================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. For Neon DB, get this from your Neon dashboard:
#   Project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@host/dbname

# ── Application Secret Keys ───────────────────────────────────────────────────
# Used by Flask session management. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-character-string-in-production

# Used to sign/verify JWT access tokens. Should be different from SECRET_KEY.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-jwt-secret-in-production

# ── Flask Settings ────────────────────────────────────────────────────────────
# Set FLASK_ENV=production for production deployments
FLASK_ENV=development
FLASK_DEBUG=1

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Redis / Job Queue (Optional) ──────────────────────────────────────────────
# Used for async timetable generation via RQ. If Redis is unavailable,
# the app falls back to synchronous generation automatically.
REDIS_URL=redis://localhost:6379
